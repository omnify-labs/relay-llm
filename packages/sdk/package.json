{
  "name": "@relay-llm/sdk",
  "version": "0.1.0",
  "description": "Route pi-ai models through Relay LLM proxy",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": ">=0.50.0"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.56.3",
    "typescript": "^5.7.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": ["dist", "README.md"],
  "license": "AGPL-3.0"
}
